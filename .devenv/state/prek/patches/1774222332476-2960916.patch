+            self.lfo_sign = -1.0;
+        } else if self.lfo_phase <= -1.0 {
+            self.lfo_phase = -2.0 - self.lfo_phase;
+            self.lfo_sign = 1.0;
+        }
+        self.lfo_phase
+    }
+}
