+        Self {
+            buffer: vec![0.0; 2048], write_pos: 0, buf_len: 1024,
+            lfo_phase, lfo_sign: if lfo_phase >= 0.0 { 1.0 } else { -1.0 },
+            phase_offset, z1: 0.0, lp_state: 0.0, dc_x1: 0.0, dc_y1: 0.0,
+            sample_rate: 48000.0,
