+                let enabled = bp.enabled.value() > 0.5;
+                let ft = shape_to_filter_type(bp.filter_type.value());
+                let freq = bp.freq_hz.value() as f64;
+                let gain = bp.gain_db.value() as f64;
+                let q = bp.q.value() as f64;
+
