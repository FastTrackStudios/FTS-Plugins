+                    || band.filter_type != ft
+                    || (band.freq_hz - freq).abs() > 0.01
+                    || (band.gain_db - gain).abs() > 0.01
+                    || (band.q - q).abs() > 0.001
+                {
+                    band.enabled = enabled;
+                    band.filter_type = ft;
+                    band.freq_hz = freq;
+                    band.gain_db = gain;
+                    band.q = q;
+                    band.structure = FilterStructure::Tdf2;
+                    self.chain.update_band(i);
+                }
+            }
