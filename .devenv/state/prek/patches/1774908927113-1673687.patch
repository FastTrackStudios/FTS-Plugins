+/// Design up to 2 correction biquads to compensate compound II cascade error.
+fn cascade_correction_sections(
+    fc: f64,
+    sample_rate: f64,
+    coeffs: &[coeff::Coeffs],
+    qs: &[f64],
+    is_hp: bool,
+    out: &mut [coeff::Coeffs; 2],
+) -> usize {
+    let nyq = sample_rate / 2.0;
+
+    let (f_lo, f_hi) = if is_hp {
+        (fc * 1.05, nyq * 0.95)
+    } else {
+        (20.0_f64.max(fc * 0.02), fc * 0.95)
+    };
+
+    let num_points = 64;
+    let mut errors = [(0.0_f64, 0.0_f64); 64];
+    let mut max_abs_error = 0.0_f64;
+
+    for i in 0..num_points {
+        let t = i as f64 / (num_points - 1) as f64;
+        let freq = f_lo * (f_hi / f_lo).powf(t);
+        let w = 2.0 * PI * freq / sample_rate;
