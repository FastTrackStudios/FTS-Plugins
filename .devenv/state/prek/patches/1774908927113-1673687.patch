+/// Evaluate the magnitude (dB) of a cascade of biquad sections at digital frequency `w`.
+fn cascade_mag_db(coeffs: &[coeff::Coeffs], w: f64) -> f64 {
+    let cw = w.cos();
+    let sw = w.sin();
+    let c2w = 2.0 * cw * cw - 1.0;
+    let s2w = 2.0 * sw * cw;
+    let mut mag_sq = 1.0_f64;
+    for c in coeffs {
+        let nr = c[3] + c[4] * cw + c[5] * c2w;
+        let ni = -(c[4] * sw + c[5] * s2w);
+        let dr = c[0] + c[1] * cw + c[2] * c2w;
+        let di = -(c[1] * sw + c[2] * s2w);
+        mag_sq *= (nr * nr + ni * ni) / (dr * dr + di * di).max(1e-30);
+    }
+    10.0 * mag_sq.max(1e-30).log10()
+}
+
+/// Evaluate the analog Butterworth cascade magnitude (dB) at a given frequency.
+/// LP per-section: |H|^2 = 1 / ((1 - s^2)^2 + s^2/Q^2) where s = freq/fc.
+/// HP per-section: |H|^2 = s^4 / ((1 - s^2)^2 + s^2/Q^2) where s = freq/fc.
+fn analog_cascade_mag_db(fc: f64, qs: &[f64], freq: f64, is_hp: bool) -> f64 {
+    let s = freq / fc;
+    let s2 = s * s;
+    let mut mag_sq = 1.0_f64;
+    for &q in qs {
+        let denom = (1.0 - s2).powi(2) + s2 / (q * q);
+        if is_hp {
+            mag_sq *= s2 * s2 / denom;
+        } else {
+            mag_sq /= denom;
+        }
+    }
+    10.0 * mag_sq.max(1e-30).log10()
+}
