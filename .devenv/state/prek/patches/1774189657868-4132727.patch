+    fn find_splice_offset(&self, nominal: f64, reference_offset: f64) -> f64 {
+        let buf_len = self.delay.len();
+        let tail_len = SPLICE_TAIL_LEN.min(buf_len / 4);
+        let tolerance = SPLICE_TOLERANCE as isize;
