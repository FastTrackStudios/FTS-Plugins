+
+        let mut path = BezPath::new();
+        path.move_to((-x_offset, ys[0]));
+        for i in 0..n - 1 {
+            let x0 = i as f64 * step - x_offset;
+            let x1 = (i + 1) as f64 * step - x_offset;
+            let y_prev = if i > 0 { ys[i - 1] } else { ys[0] };
