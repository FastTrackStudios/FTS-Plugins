     echo "Install:"
     echo "  just install [plugin]    Build and install to REAPER FX dir"
+    echo "  just install-all         Build and install ALL plugins"
     echo "  just uninstall [plugin]  Remove plugin from FX dir"
     echo ""
     echo "Dev:"
