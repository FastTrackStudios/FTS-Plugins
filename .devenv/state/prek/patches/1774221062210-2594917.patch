diff --git a/Justfile b/Justfile
index 5365dc3..162f123 100644
--- a/Justfile
+++ b/Justfile
@@ -39,38 +39,70 @@ build-debug plugin=PLUGIN_NAME: (bundle-debug plugin)
 
 # ── Install Commands ──────────────────────────────────────────────────
 
-# Install a bundled CLAP plugin to REAPER's FX directory
+# Install a bundled CLAP plugin via symlink to REAPER FX directories
 install plugin=PLUGIN_NAME: (bundle plugin)
     #!/usr/bin/env bash
     set -euo pipefail
 
-    # Determine FX directory (Linux vs macOS)
-    if [ "$(uname)" = "Darwin" ]; then
-        FX_DIR="{{FX_DIR_MAC}}"
-    else
-        # Use REAPER config from env if set (nix shell), else default
-        FX_DIR="{{REAPER_CONFIG}}/UserPlugins/FX"
-    fi
-
     CLAP_FILE="{{plugin}}.clap"
+    BUNDLED="$(realpath ./target/bundled/$CLAP_FILE)"
 
-    mkdir -p "$FX_DIR"
-
-    # Remove old plugin
-    if [ -e "$FX_DIR/$CLAP_FILE" ] || [ -d "$FX_DIR/$CLAP_FILE" ]; then
-        rm -rf "$FX_DIR/$CLAP_FILE"
-        echo "Removed old $CLAP_FILE"
-    fi
-
-    # Copy new plugin
-    BUNDLED="./target/bundled/$CLAP_FILE"
     if [ ! -e "$BUNDLED" ]; then
         echo "ERROR: $BUNDLED not found. Did the build succeed?"
         exit 1
     fi
 
-    cp -r "$BUNDLED" "$FX_DIR/"
-    echo "Installed: $FX_DIR/$CLAP_FILE"
+    # Symlink into both REAPER FX directories
+    if [ "$(uname)" = "Darwin" ]; then
+        FX_DIRS=("{{FX_DIR_MAC}}")
+    else
+        FX_DIRS=(
+            "{{REAPER_CONFIG}}/UserPlugins/FX"
+            "{{FX_DIR_LINUX}}"
+        )
+    fi
+
+    # Deduplicate (in case REAPER_CONFIG points to ~/.config/REAPER)
+    declare -A SEEN
+    for FX_DIR in "${FX_DIRS[@]}"; do
+        REAL_DIR="$(mkdir -p "$FX_DIR" && realpath "$FX_DIR")"
+        if [ -n "${SEEN[$REAL_DIR]+x}" ]; then
+            continue
+        fi
+        SEEN[$REAL_DIR]=1
+
+        # Remove old plugin (file, dir, or symlink)
+        DEST="$FX_DIR/$CLAP_FILE"
+        if [ -e "$DEST" ] || [ -L "$DEST" ]; then
+            rm -rf "$DEST"
+        fi
+
+        ln -s "$BUNDLED" "$DEST"
+        echo "Symlinked: $DEST -> $BUNDLED"
+    done
+
+# Install ALL plugins (bundle + symlink each one)
+install-all:
+    #!/usr/bin/env bash
+    set -euo pipefail
+    PLUGINS=(
+        comp-plugin
+        eq-plugin
+        gate-plugin
+        limiter-plugin
+        tape-plugin
+        delay-plugin
+        reverb-plugin
+        trigger-plugin
+        rider-plugin
+        fts-macros
+    )
+    for p in "${PLUGINS[@]}"; do
+        echo "── Installing $p ──"
+        just install "$p"
+        echo ""
+    done
+    echo "All plugins installed."
 
 # Install and show REAPER reload instructions
 install-reload plugin=PLUGIN_NAME: (install plugin)
@@ -79,21 +111,39 @@ install-reload plugin=PLUGIN_NAME: (install plugin)
     echo "Restart REAPER or rescan plugins to pick up the new build."
     echo "  REAPER → Options → Preferences → Plug-ins → Re-scan"
 
-# Uninstall a plugin from FX directory
+# Uninstall a plugin from all FX directories
 uninstall plugin=PLUGIN_NAME:
     #!/usr/bin/env bash
     set -euo pipefail
+    CLAP_FILE="{{plugin}}.clap"
+
     if [ "$(uname)" = "Darwin" ]; then
-        FX_DIR="{{FX_DIR_MAC}}"
+        FX_DIRS=("{{FX_DIR_MAC}}")
     else
-        FX_DIR="{{REAPER_CONFIG}}/UserPlugins/FX"
+        FX_DIRS=(
+            "{{REAPER_CONFIG}}/UserPlugins/FX"
+            "{{FX_DIR_LINUX}}"
+        )
     fi
-    CLAP_FILE="{{plugin}}.clap"
-    if [ -e "$FX_DIR/$CLAP_FILE" ] || [ -d "$FX_DIR/$CLAP_FILE" ]; then
-        rm -rf "$FX_DIR/$CLAP_FILE"
-        echo "Removed: $FX_DIR/$CLAP_FILE"
-    else
-        echo "Not found: $FX_DIR/$CLAP_FILE"
+
+    FOUND=0
+    declare -A SEEN
+    for FX_DIR in "${FX_DIRS[@]}"; do
+        [ -d "$FX_DIR" ] || continue
+        REAL_DIR="$(realpath "$FX_DIR")"
+        [ -n "${SEEN[$REAL_DIR]+x}" ] && continue
+        SEEN[$REAL_DIR]=1
+
+        DEST="$FX_DIR/$CLAP_FILE"
+        if [ -e "$DEST" ] || [ -L "$DEST" ]; then
+            rm -rf "$DEST"
+            echo "Removed: $DEST"
+            FOUND=1
+        fi
+    done
+
+    if [ "$FOUND" = "0" ]; then
+        echo "Not found: $CLAP_FILE"
     fi
 
 # ── REAPER Commands ───────────────────────────────────────────────────
@@ -211,6 +261,7 @@ help:
