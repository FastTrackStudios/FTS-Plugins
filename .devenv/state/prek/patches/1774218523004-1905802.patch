+            let dry_r = right[i];
+
+            // Input filtering
+            let filt_l = self.input_lp.tick(self.input_hp.tick(dry_l, 0), 0);
+            let filt_r = self.input_lp.tick(self.input_hp.tick(dry_r, 1), 1);
