+        let mut l: Vec<f64> = (0..n).map(|i| if i < 10 { 1.0 } else { 0.0 }).collect();
+        let mut r = l.clone();
+
+        c.process(&mut l, &mut r);
+
+        // Wet signal should have energy after the impulse
