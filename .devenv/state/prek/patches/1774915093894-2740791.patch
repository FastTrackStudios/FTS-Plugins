+    /// Build a smooth filled BezPath from sample data.
+    /// Uses Catmull-Rom → cubic Bézier conversion for smooth interpolation.
+    fn build_smooth_path(samples: &[f32], w: f64, h: f64, from_bottom: bool) -> BezPath {
+        let n = samples.len();
+        if n == 0 {
+            return BezPath::new();
+        }
+
+        let step = w / n as f64;
+
+        // Convert samples to y-coordinates
+        let ys: Vec<f64> = samples
+            .iter()
+            .map(|&s| {
+                let amp = s.clamp(0.0, 1.0) as f64;
+                if from_bottom {
+                    h - amp * h // level: 0 at bottom, 1 at top
+                } else {
+                    amp * h // GR: 0 at top, 1 going down
+                }
+            })
+            .collect();
+
+        let mut path = BezPath::new();
+        // Start at baseline
+        let baseline = if from_bottom { h } else { 0.0 };
+        path.move_to((0.0, baseline));
+
+        // First point on curve
+        path.line_to((0.0, ys[0]));
+
+        // Catmull-Rom to cubic Bézier for each segment
+        for i in 0..n - 1 {
+            let x0 = i as f64 * step;
+            let x1 = (i + 1) as f64 * step;
+
+            let y_prev = if i > 0 { ys[i - 1] } else { ys[0] };
+            let y_curr = ys[i];
+            let y_next = ys[i + 1];
+            let y_next2 = if i + 2 < n { ys[i + 2] } else { ys[n - 1] };
+
+            // Catmull-Rom tangents (tension = 0 for standard smooth)
+            let t1_y = (y_next - y_prev) / 2.0;
+            let t2_y = (y_next2 - y_curr) / 2.0;
+            let seg = step;
+
+            // Convert to cubic Bézier control points
+            let cp1x = x0 + seg / 3.0;
+            let cp1y = y_curr + t1_y / 3.0;
+            let cp2x = x1 - seg / 3.0;
+            let cp2y = y_next - t2_y / 3.0;
+
+            path.curve_to((cp1x, cp1y), (cp2x, cp2y), (x1, y_next));
+        }
+
+        // Close to baseline
+        path.line_to((w, baseline));
+        path.close_path();
+        path
+    }
+}
