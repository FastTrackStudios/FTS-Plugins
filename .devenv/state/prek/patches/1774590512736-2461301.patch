+fn screenshot_delay(output: &std::path::Path) {
+    use delay_plugin::{DelayUiState, FtsDelayParams};
+
+    let width = 900;
+    let height = 540;
+
+    let params = Arc::new(FtsDelayParams::default());
+    let ui_state = Arc::new(DelayUiState {
+        params,
+        input_peak_db: AtomicF32::new(-100.0),
+        output_peak_db: AtomicF32::new(-100.0),
+    });
+    let shared = SharedState::new(ui_state);
+
+    eprintln!("Rendering delay ({}x{})...", width, height);
+    let pixels =
+        nih_plug_dioxus::render_screenshot(delay_plugin::editor::App, width, height, Some(shared));
+    save_png(&pixels, width, height, output);
+}
+
