+// ─── Detune Engine (Constant-Detune) ──────────────────────────────
+
+/// Constant-detune chorus: depth in cents stays constant regardless
+/// of modulation rate. Delay excursion = K / rate to maintain constant
+/// pitch deviation. Based on magnetophon/constant-detune-chorus.
+pub struct DetuneVoice {
+    delay: DelayLine,
+    slow_phase: f64,
+    fast_phase: f64,
+    phase_offset: f64,
+    dc_x1: f64,
+    dc_y1: f64,
+    sample_rate: f64,
+}
+
+impl DetuneVoice {
+    const MAX_DELAY: usize = 192000 / 10 + 64;
+    const BASE_DELAY_MS: f64 = 10.0;
+    /// Default detune depth in cents when depth=1.0.
+    const MAX_DETUNE_CENTS: f64 = 12.0;
+    const DC_COEFF: f64 = 0.995;
+
+    pub fn new(phase_offset: f64) -> Self {
+        Self {
+            delay: DelayLine::new(Self::MAX_DELAY),
+            slow_phase: phase_offset,
+            fast_phase: phase_offset * 1.37,
+            phase_offset,
+            dc_x1: 0.0,
+            dc_y1: 0.0,
+            sample_rate: 48000.0,
+        }
+    }
+
+    /// Convert cents to delay excursion in samples, normalized by frequency
+    /// so pitch deviation stays constant: excursion = K / freq.
+    #[inline]
+    fn cents_to_excursion(&self, cents: f64, freq_hz: f64) -> f64 {
+        if freq_hz < 0.001 {
+            return 0.0;
+        }
+        let ratio = 2.0_f64.powf(cents / 1200.0);
+        self.sample_rate * (ratio - 1.0) / (ratio + 1.0) / freq_hz
+    }
+}
+
+impl ChorusEngine for DetuneVoice {
+    fn update(&mut self, sample_rate: f64) {
+        self.sample_rate = sample_rate;
+        let needed = (sample_rate * 0.1) as usize + 64;
+        if self.delay.len() < needed {
+            self.delay = DelayLine::new(needed);
+        }
+    }
+
+    fn tick(
+        &mut self,
+        input: f64,
+        rate_hz: f64,
+        depth: f64,
+        feedback: f64,
+        _color: f64,
+        effect_type: EffectType,
+    ) -> f64 {
+        let slow_rate = rate_hz;
+        let fast_rate = rate_hz * 1.73;
+
+        self.slow_phase = (self.slow_phase + slow_rate / self.sample_rate).fract();
+        self.fast_phase = (self.fast_phase + fast_rate / self.sample_rate).fract();
+
+        // Asymmetric triangle: 1/3 rise, 2/3 fall → symmetric pitch shift
+        fn asym_triangle(phase: f64) -> f64 {
+            if phase < 1.0 / 3.0 {
+                phase * 3.0
+            } else {
+                1.0 - (phase - 1.0 / 3.0) * 3.0
+            }
+        }
+
+        let slow_lfo = asym_triangle(self.slow_phase);
+        let fast_lfo = (self.fast_phase * 2.0 * PI).sin();
+
+        let detune_cents = Self::MAX_DETUNE_CENTS * depth;
+        let slow_excursion = self.cents_to_excursion(detune_cents * 0.7, slow_rate);
+        let fast_excursion = self.cents_to_excursion(detune_cents * 0.3, fast_rate);
+
+        let base_delay = match effect_type {
+            EffectType::Chorus => Self::BASE_DELAY_MS,
+            EffectType::Flanger => 3.0,
+            EffectType::Vibrato => 6.0,
+        };
+        let base_samples = base_delay * 0.001 * self.sample_rate;
+        let mod_samples = slow_lfo * slow_excursion + fast_lfo * fast_excursion;
+        let delay_samples =
+            (base_samples + mod_samples).clamp(1.0, self.delay.len() as f64 - 4.0);
+
+        let delayed = self.delay.read_cubic(delay_samples);
+        let fb = (delayed * feedback).tanh();
+        self.delay.write(input + fb);
+
+        // DC blocker
+        let dc_out = delayed - self.dc_x1 + Self::DC_COEFF * self.dc_y1;
+        self.dc_x1 = delayed;
+        self.dc_y1 = dc_out;
+
+        dc_out
+    }
+
+    fn reset(&mut self) {
+        self.delay.clear();
+        self.slow_phase = self.phase_offset;
+        self.fast_phase = self.phase_offset * 1.37;
+        self.dc_x1 = 0.0;
+        self.dc_y1 = 0.0;
+    }
+}
+
+// ─── Diffuse Engine (Allpass Cascade) ─────────────────────────────
+
+/// Diffuse allpass chorus: cascaded modulated allpass filters creating
+/// a hybrid chorus/reverb texture. Based on Valhalla DSP concepts.
+pub struct DiffuseVoice {
+    stages: [AllpassStage; 4],
+    phase_offset: f64,
+    sample_rate: f64,
+}
+
+/// Single modulated allpass stage.
+struct AllpassStage {
+    buffer: Vec<f64>,
+    write_pos: usize,
+    buf_len: usize,
+    lfo_phase: f64,
+    lfo_rate_scale: f64,
+    base_delay_samples: f64,
+}
+
+impl AllpassStage {
+    fn new(base_delay_ms: f64, lfo_rate_scale: f64) -> Self {
+        let max_samples = (48000.0 * base_delay_ms * 0.002) as usize + 16;
+        Self {
+            buffer: vec![0.0; max_samples],
+            write_pos: 0,
+            buf_len: max_samples,
+            lfo_phase: 0.0,
+            lfo_rate_scale,
+            base_delay_samples: 0.0,
+        }
+    }
+
+    fn update(&mut self, sample_rate: f64, base_delay_ms: f64) {
+        self.base_delay_samples = base_delay_ms * 0.001 * sample_rate;
+        let needed = (self.base_delay_samples * 2.0) as usize + 16;
+        if self.buffer.len() < needed {
+            self.buffer.resize(needed, 0.0);
+        }
+        self.buf_len = self.buffer.len();
+    }
+
+    fn reset(&mut self) {
+        self.buffer.fill(0.0);
+        self.write_pos = 0;
+    }
+
+    #[inline]
+    fn tick(
+        &mut self,
+        input: f64,
+        rate_hz: f64,
+        depth: f64,
+        coeff: f64,
+        sample_rate: f64,
+    ) -> f64 {
+        let rate = rate_hz * self.lfo_rate_scale;
+        self.lfo_phase = (self.lfo_phase + rate / sample_rate).fract();
+        let lfo = (self.lfo_phase * 2.0 * PI).sin();
+
+        let mod_samples = depth * self.base_delay_samples * 0.15 * lfo;
+        let delay = (self.base_delay_samples + mod_samples)
+            .clamp(1.0, (self.buf_len - 2) as f64);
+
+        let int_delay = delay.floor() as usize;
+        let frac = delay - delay.floor();
+        let idx0 = (self.write_pos + self.buf_len - int_delay) % self.buf_len;
+        let idx1 = (idx0 + self.buf_len - 1) % self.buf_len;
+        let delayed = self.buffer[idx0] * (1.0 - frac) + self.buffer[idx1] * frac;
+
+        // Schroeder allpass: y = delayed + g*(input - delayed)
+        let output = delayed + coeff * (input - delayed);
+        self.buffer[self.write_pos] = input + coeff * delayed;
+        self.write_pos = (self.write_pos + 1) % self.buf_len;
+
+        output
+    }
+
+    /// Last written sample for feedback tapping.
+    fn last_output(&self) -> f64 {
+        let prev = if self.write_pos == 0 {
+            self.buf_len - 1
+        } else {
+            self.write_pos - 1
+        };
+        self.buffer[prev]
+    }
+}
+
+impl DiffuseVoice {
+    /// Mutually prime-ish delay times in ms for 4 stages.
+    const STAGE_DELAYS_MS: [f64; 4] = [5.3, 7.1, 11.3, 3.7];
+    /// LFO rate multipliers per stage (independent modulation).
+    const STAGE_RATE_SCALES: [f64; 4] = [1.0, 0.77, 1.33, 0.57];
+
+    pub fn new(phase_offset: f64) -> Self {
+        let mut stages = [
+            AllpassStage::new(Self::STAGE_DELAYS_MS[0], Self::STAGE_RATE_SCALES[0]),
+            AllpassStage::new(Self::STAGE_DELAYS_MS[1], Self::STAGE_RATE_SCALES[1]),
+            AllpassStage::new(Self::STAGE_DELAYS_MS[2], Self::STAGE_RATE_SCALES[2]),
+            AllpassStage::new(Self::STAGE_DELAYS_MS[3], Self::STAGE_RATE_SCALES[3]),
+        ];
+        for (i, stage) in stages.iter_mut().enumerate() {
+            stage.lfo_phase = (phase_offset + i as f64 * 0.25).fract();
+        }
+        Self {
+            stages,
+            phase_offset,
+            sample_rate: 48000.0,
+        }
+    }
+}
+
+impl ChorusEngine for DiffuseVoice {
+    fn update(&mut self, sample_rate: f64) {
+        self.sample_rate = sample_rate;
+        for (i, stage) in self.stages.iter_mut().enumerate() {
+            stage.update(sample_rate, Self::STAGE_DELAYS_MS[i]);
+        }
+    }
+
+    fn tick(
+        &mut self,
+        input: f64,
+        rate_hz: f64,
+        depth: f64,
+        feedback: f64,
+        color: f64,
+        _effect_type: EffectType,
+    ) -> f64 {
+        let coeff = 0.3 + color * 0.4;
+
+        // Feed back from last stage
+        let fb_sample = self.stages[3].last_output() * feedback * 0.4;
+        let mut x = (input + fb_sample).clamp(-1.5, 1.5);
+        for stage in &mut self.stages {
+            x = stage.tick(x, rate_hz, depth, coeff, self.sample_rate);
+        }
+
+        x
+    }
+
+    fn reset(&mut self) {
+        for (i, stage) in self.stages.iter_mut().enumerate() {
+            stage.reset();
+            stage.lfo_phase = (self.phase_offset + i as f64 * 0.25).fract();
+        }
+    }
+}
+
+// ─── Drift Engine (Random Walk LFO) ──────────────────────────────
+
+/// Smooth random-walk LFO chorus: organic, non-periodic modulation.
+/// Based on musicdsp.org smooth random LFO generator.
+pub struct DriftVoice {
+    delay: DelayLine,
+    phase_offset: f64,
+    sample_rate: f64,
+    x: f64,
+    a: f64,
+    new_a: f64,
+    last_a: f64,
+    an: usize,
+    cn: usize,
+    amp_scale: f64,
+    new_amp: f64,
+    last_sign: bool,
+    rng_state: u64,
+}
+
+impl DriftVoice {
+    const MAX_DELAY: usize = 192000 / 20 + 64;
+
+    pub fn new(phase_offset: f64) -> Self {
+        let seed = ((phase_offset * 1e9) as u64).wrapping_add(0x517cc1b727220a95);
+        Self {
+            delay: DelayLine::new(Self::MAX_DELAY),
+            phase_offset,
+            sample_rate: 48000.0,
+            x: phase_offset * 2.0 * PI,
+            a: 0.5,
+            new_a: 0.5,
+            last_a: 0.5,
+            an: 0,
+            cn: 1,
+            amp_scale: 1.0,
+            new_amp: 1.0,
+            last_sign: true,
+            rng_state: seed.max(1),
+        }
+    }
+
+    #[inline]
+    fn rand(&mut self) -> f64 {
+        let mut x = self.rng_state;
+        x ^= x << 13;
+        x ^= x >> 7;
+        x ^= x << 17;
+        self.rng_state = x;
+        (x & 0x7FFFFFFF) as f64 / 0x80000000u64 as f64
+    }
+
+    #[inline]
+    fn next_lfo(&mut self, rate_hz: f64) -> f64 {
+        let step_scale = self.sample_rate / rate_hz.max(0.01);
+
+        self.an += 1;
+        if self.an >= self.cn {
+            self.last_a = self.new_a;
+            self.new_a = 0.1 + 0.9 * self.rand();
+            self.cn = ((step_scale * self.rand()).max(step_scale * 0.1)) as usize;
+            self.cn = self.cn.max(1);
+            self.an = 0;
+        }
+        self.a = self.last_a + (self.new_a - self.last_a) * (self.an as f64 / self.cn as f64);
+
+        let inc = 2.0 * PI * rate_hz * self.a / self.sample_rate;
+        self.x += inc;
+        if self.x >= 2.0 * PI {
+            self.x -= 2.0 * PI;
+        }
+
+        let raw = self.x.sin();
+
+        let sign = raw >= 0.0;
+        if sign != self.last_sign {
+            self.new_amp = 0.25 + 0.75 * self.rand();
+        }
+        self.last_sign = sign;
+
+        let ramp = ((1000.0 / self.sample_rate).exp()) - 1.0;
+        self.amp_scale += (self.new_amp - self.amp_scale) * ramp.clamp(0.001, 0.5);
+
+        raw * self.amp_scale
+    }
+}
+
+impl ChorusEngine for DriftVoice {
+    fn update(&mut self, sample_rate: f64) {
+        self.sample_rate = sample_rate;
+        let needed = (sample_rate * 0.05) as usize + 64;
+        if self.delay.len() < needed {
+            self.delay = DelayLine::new(needed);
+        }
+    }
+
+    fn tick(
+        &mut self,
+        input: f64,
+        rate_hz: f64,
+        depth: f64,
+        feedback: f64,
+        _color: f64,
+        effect_type: EffectType,
+    ) -> f64 {
+        let lfo = self.next_lfo(rate_hz);
+        let base_ms = effect_type.base_delay_ms();
+        let depth_ms = effect_type.max_depth_ms() * depth;
+        let delay_samples = ((base_ms + depth_ms * lfo) * 0.001 * self.sample_rate)
+            .clamp(1.0, self.delay.len() as f64 - 4.0);
+        let delayed = self.delay.read_cubic(delay_samples);
+        self.delay
+            .write(input + (delayed * feedback).clamp(-1.5, 1.5));
+        delayed
+    }
+
+    fn reset(&mut self) {
+        self.delay.clear();
+        self.x = self.phase_offset * 2.0 * PI;
+        self.a = 0.5;
+        self.new_a = 0.5;
+        self.last_a = 0.5;
+        self.an = 0;
+        self.cn = 1;
+        self.amp_scale = 1.0;
+        self.new_amp = 1.0;
+        self.last_sign = true;
+    }
+}
