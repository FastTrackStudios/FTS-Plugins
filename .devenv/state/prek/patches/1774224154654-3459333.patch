+// ─── Ensemble Engine (Solina) ──────────────────────────────────────
+
+/// Solina-style ensemble: 3 internal BBD lines per voice with paired
+/// slow (chorus) + fast (vibrato) LFOs at 120° phase offsets.
+pub struct EnsembleVoice {
+    delays: [DelayLine; 3],
+    /// Slow LFO phases for 3 lines (0°, 120°, 240°).
+    slow_phases: [f64; 3],
+    /// Fast LFO phases for 3 lines.
+    fast_phases: [f64; 3],
+    phase_offset: f64,
+    output_lp: [f64; 3],
+    sample_rate: f64,
+}
+
+impl EnsembleVoice {
+    const MAX_DELAY: usize = 192000 / 20 + 64;
+    const SLOW_RATE_SCALE: f64 = 1.0;
+    const FAST_RATE_SCALE: f64 = 6.0;
+    /// Base delay times for the 3 lines (ms), slightly staggered.
+    const BASE_DELAYS_MS: [f64; 3] = [7.0, 8.5, 6.2];
+
+    pub fn new(phase_offset: f64) -> Self {
+        Self {
+            delays: [
+                DelayLine::new(Self::MAX_DELAY),
+                DelayLine::new(Self::MAX_DELAY),
+                DelayLine::new(Self::MAX_DELAY),
+            ],
+            slow_phases: [
+                phase_offset,
+                phase_offset + 1.0 / 3.0,
+                phase_offset + 2.0 / 3.0,
+            ],
+            fast_phases: [
+                phase_offset,
+                phase_offset + 1.0 / 3.0,
+                phase_offset + 2.0 / 3.0,
+            ],
+            phase_offset,
+            output_lp: [0.0; 3],
+            sample_rate: 48000.0,
+        }
+    }
+}
+
+impl ChorusEngine for EnsembleVoice {
+    fn update(&mut self, sample_rate: f64) {
+        self.sample_rate = sample_rate;
+        let needed = (sample_rate * 0.05) as usize + 64;
+        for d in &mut self.delays {
+            if d.len() < needed {
+                *d = DelayLine::new(needed);
+            }
+        }
+    }
+
+    fn tick(
+        &mut self,
+        input: f64,
+        rate_hz: f64,
+        depth: f64,
+        feedback: f64,
+        color: f64,
+        effect_type: EffectType,
+    ) -> f64 {
+        let slow_rate = rate_hz * Self::SLOW_RATE_SCALE;
+        let fast_rate = rate_hz * Self::FAST_RATE_SCALE;
+        let slow_inc = slow_rate / self.sample_rate;
+        let fast_inc = fast_rate / self.sample_rate;
+
+        let base_ms = effect_type.base_delay_ms();
+        let depth_ms = effect_type.max_depth_ms() * depth;
+        let max_d = self.delays[0].len() as f64 - 4.0;
+
+        // Output LP cutoff controlled by color
+        let cutoff = 4000.0 + color * 14000.0;
+        let lp_coeff = (2.0 * PI * cutoff / self.sample_rate)
+            .sin()
+            .clamp(0.0, 0.99);
+
+        let mut sum = 0.0;
+        for i in 0..3 {
+            self.slow_phases[i] = (self.slow_phases[i] + slow_inc).fract();
+            self.fast_phases[i] = (self.fast_phases[i] + fast_inc).fract();
+
+            let slow_lfo = (self.slow_phases[i] * 2.0 * PI).sin();
+            let fast_lfo = (self.fast_phases[i] * 2.0 * PI).sin();
+
+            // Combined: slow dominates, fast adds shimmer
+            let mod_val = slow_lfo * 0.7 + fast_lfo * 0.3;
+
+            let delay_ms = Self::BASE_DELAYS_MS[i] + base_ms * 0.3 + depth_ms * mod_val;
+            let delay_samp = (delay_ms * 0.001 * self.sample_rate).clamp(1.0, max_d);
+            let delayed = self.delays[i].read_cubic(delay_samp);
+
+            self.output_lp[i] += (delayed - self.output_lp[i]) * lp_coeff;
+            sum += self.output_lp[i];
+
+            let fb = (delayed * feedback * 0.3).clamp(-1.0, 1.0);
+            self.delays[i].write(input + fb);
+        }
+
+        sum / 3.0
+    }
+
+    fn reset(&mut self) {
+        for d in &mut self.delays {
+            d.clear();
+        }
+        self.slow_phases = [
+            self.phase_offset,
+            self.phase_offset + 1.0 / 3.0,
+            self.phase_offset + 2.0 / 3.0,
+        ];
+        self.fast_phases = self.slow_phases;
+        self.output_lp = [0.0; 3];
+    }
+}
