     #!/usr/bin/env bash
     set -euo pipefail
+    CLAP_FILE="{{plugin}}.clap"
+
     if [ "$(uname)" = "Darwin" ]; then
-        FX_DIR="{{FX_DIR_MAC}}"
+        FX_DIRS=("{{FX_DIR_MAC}}")
     else
-        FX_DIR="{{REAPER_CONFIG}}/UserPlugins/FX"
+        FX_DIRS=(
