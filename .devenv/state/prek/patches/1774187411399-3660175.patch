+// ── Anti-cramping correction ────────────────────────────────────────
+
+/// RBJ cookbook peak (standard BLT, cramps at Nyquist).
+pub fn peak_blt(freq_hz: f64, q: f64, gain_db: f64, sample_rate: f64) -> Coeffs {
+    let g = 10.0_f64.powf(gain_db / 20.0);
+    if (g - 1.0).abs() < 1e-6 {
+        return PASSTHROUGH;
+    }
+    let w0 = (2.0 * PI * freq_hz / sample_rate).clamp(1e-6, PI - 1e-6);
+    let a_amp = g.sqrt(); // A = √G
+    let sin_w0 = w0.sin();
+    let cos_w0 = w0.cos();
+    let alpha = sin_w0 / (2.0 * q);
+    let a0 = 1.0 + alpha / a_amp;
+    let a1 = -2.0 * cos_w0;
+    let a2 = 1.0 - alpha / a_amp;
+    let b0 = 1.0 + alpha * a_amp;
+    let b1 = -2.0 * cos_w0;
+    let b2 = 1.0 - alpha * a_amp;
+    let a0_inv = 1.0 / a0;
+    [1.0, a1 * a0_inv, a2 * a0_inv, b0 * a0_inv, b1 * a0_inv, b2 * a0_inv]
+}
+
+/// Compute the analog peak filter's gain (in dB) at Nyquist.
+///
+/// The analog prototype peaking EQ (constant-Q) has:
+///   |H(jΩ)|² = ((1-Ω²)² + Ω²·A²/Q²) / ((1-Ω²)² + Ω²/(A²·Q²))
+/// where Ω = f_nyquist / f_center, A = 10^(gain_db/40).
+pub fn analog_peak_gain_at_nyquist(freq_hz: f64, q: f64, gain_db: f64, sample_rate: f64) -> f64 {
+    let a_amp = 10.0_f64.powf(gain_db / 40.0); // A = √G
+    let omega = (sample_rate / 2.0) / freq_hz; // Nyquist / center
+    let omega_sq = omega * omega;
+    let q_sq = q * q;
+    let a_sq = a_amp * a_amp;
+    let diff_sq = (1.0 - omega_sq) * (1.0 - omega_sq);
+    let num = diff_sq + omega_sq * a_sq / q_sq;
+    let den = diff_sq + omega_sq / (a_sq * q_sq);
+    let mag_sq = num / den;
+    10.0 * mag_sq.log10() // Convert to dB
+}
+
+/// Corrective high shelf to compensate for BLT peak cramping.
+/// Applies the analog peak's Nyquist gain as a gentle shelf.
+pub fn peak_correction_shelf(
+    freq_hz: f64,
+    correction_db: f64,
+    sample_rate: f64,
+) -> Coeffs {
+    if correction_db.abs() < 0.01 {
+        return PASSTHROUGH;
+    }
+    // Place the shelf at a high frequency to only affect the upper octaves.
+    // Use a 1st-order high shelf for minimal phase impact.
+    let shelf_freq = freq_hz.max(sample_rate * 0.25); // At least Nyquist/2
+    let shelf_freq = shelf_freq.min(sample_rate * 0.48); // Below Nyquist
+    high_shelf_1(shelf_freq, correction_db, sample_rate)
+}
