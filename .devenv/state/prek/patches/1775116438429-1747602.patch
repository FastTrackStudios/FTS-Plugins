index 021f962..aea7965 100644
--- a/crates/fts-eq/eq-pro-dsp/src/shelf_zpk.rs
+++ b/crates/fts-eq/eq-pro-dsp/src/shelf_zpk.rs
@@ -302,7 +302,11 @@ fn compute_effective_q(user_q: f64, filter_type: u32) -> f64 {
