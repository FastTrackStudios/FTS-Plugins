+    // Corner: |H(w0)|² = G (half-gain point in dB)
+    let target = g * (a0_big * p0 + a1_big * p1 + a2_big * 4.0 * p0 * p1);
+    let b2_big = (target - b0_big * p0 - b1_big * p1) / (4.0 * p0 * p1);
+
+    let (b0, b1, b2) = mag_sq_to_b([b0_big.max(0.0), b1_big.max(0.0), b2_big]);
