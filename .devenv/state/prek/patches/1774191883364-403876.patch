+/// Use xdg-desktop-portal's FileChooser via a Python helper script.
+///
+/// This calls the portal D-Bus interface which shows the system's native
+/// file chooser (GNOME, KDE, etc.) regardless of whether zenity is installed.
+#[cfg(target_os = "linux")]
+fn pick_file_portal(title: &str, extensions: &[&str]) -> Option<PathBuf> {
+    // Build glob patterns for the portal filter
+    let globs: Vec<String> = extensions.iter().map(|e| format!("*.{e}")).collect();
+    let glob_list = globs.join(",");
+
+    // Python script that uses the portal via GLib's D-Bus bindings.
+    // This is synchronous — it blocks until the user picks a file or cancels.
+    let script = format!(
+        r#"
+import subprocess, sys, os, re, time, signal
+
+# Use gdbus monitor to watch for the Response signal, then call OpenFile.
+# Portal flow: OpenFile returns a request path, then emits Response on it.
+
+import json
+
+# Build the filter option for OpenFile
+# Portal expects: a]a(sa(us))]] = array of (name, [(glob_style, pattern)])
+# We pass it as a GVariant string.
+globs = {glob_list!r}.split(",")
+filter_entries = " ".join(f"(uint32 0, '{g}')" for g in globs)
+filters = f"('Files', [{{filter_entries}}])"
+all_filter = "('All Files', [(uint32 0, '*')])"
+
+# Generate a unique handle token
+import random
+token = f"fts_{{random.randint(100000, 999999)}}"
+handle_token = f"handle_token"
+
+# Start gdbus monitor in background to catch the Response signal
+monitor = subprocess.Popen(
+    ["gdbus", "monitor", "--session", "--dest", "org.freedesktop.portal.Desktop",
+     "--object-path", "/org/freedesktop/portal/desktop"],
+    stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, text=True
+)
+
+# Call OpenFile
+result = subprocess.run(
+    ["gdbus", "call", "--session",
+     "--dest", "org.freedesktop.portal.Desktop",
+     "--object-path", "/org/freedesktop/portal/desktop",
+     "--method", "org.freedesktop.portal.FileChooser.OpenFile",
+     "",  # parent window
+     "{title}",
+     f"{{{{{{handle_token}}: <'{token}'>, 'filters': <[{filters}, {all_filter}]>}}}}"],
+    capture_output=True, text=True, timeout=5
+)
+
+if result.returncode != 0:
+    monitor.kill()
+    sys.exit(1)
+
+# Wait for Response signal (timeout 120s)
+signal.signal(signal.SIGALRM, lambda *_: sys.exit(1))
+signal.alarm(120)
+
+for line in monitor.stdout:
+    if "Response" in line and "uris" in line:
+        # Extract URI from the response
+        match = re.search(r"file://(/[^'\"]+)", line)
+        if match:
+            path = match.group(1)
+            # URL-decode the path
+            from urllib.parse import unquote
+            path = unquote(path)
+            print(path)
+            monitor.kill()
+            sys.exit(0)
+        # Response with no matching URI means cancel (code != 0)
+        monitor.kill()
+        sys.exit(1)
+
+monitor.kill()
+sys.exit(1)
+"#,
+    );
+
+    let output = Command::new("python3")
+        .args(["-c", &script])
+        .output()
+        .ok()?;
+
+    if output.status.success() {
+        let path = String::from_utf8_lossy(&output.stdout).trim().to_string();
+        if path.is_empty() {
+            None
+        } else {
+            Some(PathBuf::from(path))
+        }
+    } else {
+        None
+    }
+}
