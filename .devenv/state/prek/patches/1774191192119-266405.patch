+/// 2nd-order matched shelf from cascading two 1st-order matched shelves.
+/// Each sub-shelf gets √g gain, so cascaded total = g.
+pub fn low_shelf_2_matched(freq_hz: f64, gain_db: f64, sample_rate: f64) -> Coeffs {
+    let half_gain = gain_db / 2.0;
+    let c1 = low_shelf_1(freq_hz, half_gain, sample_rate);
+    let c2 = low_shelf_1(freq_hz, half_gain, sample_rate);
+    convolve_1pole(c1, c2)
+}
+
+/// 2nd-order matched shelf from cascading two 1st-order matched shelves.
+pub fn high_shelf_2_matched(freq_hz: f64, gain_db: f64, sample_rate: f64) -> Coeffs {
+    let half_gain = gain_db / 2.0;
+    let c1 = high_shelf_1(freq_hz, half_gain, sample_rate);
+    let c2 = high_shelf_1(freq_hz, half_gain, sample_rate);
+    convolve_1pole(c1, c2)
+}
+
+/// Convolve two 1st-order filters into a single 2nd-order biquad.
+fn convolve_1pole(c1: Coeffs, c2: Coeffs) -> Coeffs {
+    [
+        1.0,
+        c1[1] + c2[1],
+        c1[1] * c2[1],
+        c1[3] * c2[3],
+        c1[3] * c2[4] + c1[4] * c2[3],
+        c1[4] * c2[4],
+    ]
+}
+
