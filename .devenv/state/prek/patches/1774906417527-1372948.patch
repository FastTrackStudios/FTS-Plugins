+/// Uses 3-point magnitude matching (Vicanek style) to fit a correction
+/// biquad that inverts the digital-vs-analog error at DC, the error peak
+/// frequency, and Nyquist.
+fn cascade_correction(
+    fc: f64,
+    sample_rate: f64,
+    coeffs: &[coeff::Coeffs],
+    qs: &[f64],
+    is_hp: bool,
+) -> Option<coeff::Coeffs> {
+    let nyq = sample_rate / 2.0;
+
+    // Scan passband for the frequency of maximum error
+    let (f_lo, f_hi) = if is_hp {
+        (fc * 1.05, nyq * 0.95)
+    } else {
+        (20.0_f64.max(fc * 0.02), fc * 0.95)
+    };
+
+    let num_points = 80;
+    let mut max_abs_error = 0.0_f64;
+    let mut peak_freq = fc * 0.5;
+    let mut peak_error_linear_sq = 1.0_f64;
+
+    for i in 0..num_points {
+        let t = i as f64 / (num_points - 1) as f64;
+        let freq = f_lo * (f_hi / f_lo).powf(t);
+        let w = 2.0 * PI * freq / sample_rate;
+
+        let dig_db = cascade_mag_db(coeffs, w);
+        let ana_db = analog_cascade_mag_db(fc, qs, freq, is_hp);
+        let error = dig_db - ana_db;
+
+        if error.abs() > max_abs_error {
+            max_abs_error = error.abs();
+            peak_freq = freq;
+            // Correction: we want analog/digital ratio as magnitude squared
+            let ratio = 10.0_f64.powf((ana_db - dig_db) / 10.0);
+            peak_error_linear_sq = ratio;
+        }
+    }
+
+    eprintln!(
+        "cascade_correction: fc={:.0} is_hp={} peak_freq={:.0} error={:.3}dB corr_sq={:.4}",
+        fc, is_hp, peak_freq, max_abs_error, peak_error_linear_sq
+    );
+
+    // Only correct if error exceeds threshold
+    if max_abs_error < 0.5 {
+        eprintln!("  -> error below threshold, skipping");
+        return None;
+    }
+
+    // Place correction poles at the error peak frequency with moderate Q
+    let w_peak = 2.0 * PI * peak_freq / sample_rate;
+    // Use a low Q for broad correction (the error is very broad)
+    let corr_q = 0.6;
+    let sigma = 0.5 / corr_q;
+
+    let t = (-sigma * w_peak).exp();
+    let wd = (1.0 - sigma * sigma).max(0.0).sqrt();
+    let a1 = -2.0 * t * (wd * w_peak).cos();
+    let a2 = t * t;
+
+    // 3-point matching for numerator: DC=1, Nyquist=1, peak_freq=correction
+    let a0_big = (1.0 + a1 + a2).powi(2);
+    let a1_big = (1.0 - a1 + a2).powi(2);
+    let a2_big = -4.0 * a2;
+
+    let p0_peak = 0.5 + 0.5 * w_peak.cos();
+    let p1_peak = 0.5 - 0.5 * w_peak.cos();
+
+    // DC target: correction = 1.0 (no change)
+    let b0_big = a0_big; // DC gain = 1
+
+    // Nyquist target: correction = 1.0 (no change)
+    let b1_big = a1_big; // Nyquist gain = 1
+
+    // Peak target: correction = analog/digital ratio
+    let den_at_peak = a0_big * p0_peak + a1_big * p1_peak + a2_big * p0_peak * p1_peak * 4.0;
+    let target = peak_error_linear_sq * den_at_peak;
+    let b2_big = (target - b0_big * p0_peak - b1_big * p1_peak) / (4.0 * p0_peak * p1_peak);
+
+    // Convert B0², B1², B2 to b0, b1, b2
+    let b0_sq = b0_big.max(0.0);
+    let b1_sq = b1_big.max(0.0);
+    let b0_sqrt = b0_sq.sqrt();
+    let b1_sqrt = b1_sq.sqrt();
+
+    // When DC=Nyquist=1 and we have a dip, B2 is negative
+    let w_val = (b0_sqrt + b1_sqrt) / 2.0;
+    let disc = w_val * w_val + b2_big;
+    if disc < 0.0 {
+        eprintln!("  -> disc<0, skipping correction");
+        return None; // Can't form valid coefficients
+    }
+    let b0 = (w_val + disc.sqrt()) / 2.0;
+    let b0 = b0.max(1e-30);
+    let b1 = (b0_sqrt - b1_sqrt) / 2.0;
+    let b2 = -b2_big / (4.0 * b0);
+
+    Some([1.0, a1, a2, b0, b1, b2])
+}
