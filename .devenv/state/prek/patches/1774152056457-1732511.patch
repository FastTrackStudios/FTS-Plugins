+moire-wasm = { git = "https://github.com/bearcove/moire", rev = "13eac79" }
+moire-wire = { git = "https://github.com/bearcove/moire", rev = "13eac79" }
+
+# moire-trace-capture: tolerate broken frame-pointer chains (NixOS glibc).
+[patch."https://github.com/bearcove/moire"]
+moire-trace-capture = { path = "../forks/moire-trace-capture" }
