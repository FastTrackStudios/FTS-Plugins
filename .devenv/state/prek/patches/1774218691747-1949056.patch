+    /// The peak bridge tracks |input| with instant attack and slow fixed
+    /// decay, bridging zero crossings to produce a stable level.
     #[inline]
     pub fn tick(&mut self, input_abs: f64, feedback: f64, ch: usize) -> f64 {
