         Self {
+            peak_level: [0.0; MAX_CH],
             smooth_gr: [0.0; MAX_CH],
             prev_output: [0.0; MAX_CH],
             attack_coeff: 0.0,
             release_coeff: 0.0,
+            peak_decay_coeff: 0.0,
