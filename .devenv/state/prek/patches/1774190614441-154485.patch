+/// Vicanek matched 2nd-order Butterworth high shelf.
+/// fc is normalized frequency (freq_hz / nyquist).
+/// Five constraints: DC=1, Butterworth flatness at DC, Nyquist matches analog,
+/// match magnitude at two carefully chosen frequencies f1/f2.
+fn high_shelf_2_matched(fc: f64, g: f64) -> Coeffs {
+    let fc = fc.max(1e-6);
+    let inv_g = 1.0 / g;
+    let fc4 = fc.powi(4);
+    let pihalf = PI / 2.0;
+
+    // Nyquist magnitude squared from analog prototype
+    let h_ny = (fc4 + g) / (fc4 + inv_g);
+
+    // Two matching frequencies from Vicanek's optimized formula
+    let fc_sq = fc * fc;
+    let f1 = fc / (0.160 + 1.543 * fc_sq).sqrt();
+    let f2 = fc / (0.947 + 3.806 * fc_sq).sqrt();
+
+    // Analog magnitude squared at f1, f2
+    let f14 = f1.powi(4);
+    let h1 = (fc4 + f14 * g) / (fc4 + f14 * inv_g);
+    let phi1 = (pihalf * f1).sin().powi(2);
+
+    let f24 = f2.powi(4);
+    let h2 = (fc4 + f24 * g) / (fc4 + f24 * inv_g);
+    let phi2 = (pihalf * f2).sin().powi(2);
+
+    // Solve 2x2 linear system for α1 and α2
+    let d1 = (h1 - 1.0) * (1.0 - phi1);
+    let c11 = -phi1 * d1;
+    let c12 = phi1 * phi1 * (h_ny - h1);
+
+    let d2 = (h2 - 1.0) * (1.0 - phi2);
+    let c21 = -phi2 * d2;
+    let c22 = phi2 * phi2 * (h_ny - h2);
+
+    let det = c11 * c22 - c12 * c21;
+    if det.abs() < 1e-30 {
+        return PASSTHROUGH;
+    }
+
+    let alfa1 = (c22 * d1 - c12 * d2) / det;
+    let aa1 = (d1 - c11 * alfa1) / c12;
+    let bb1 = h_ny * aa1;
+
+    let aa2 = 0.25 * (alfa1 - aa1);
+    let bb2 = 0.25 * (alfa1 - bb1);
+
+    // Recover transfer function coefficients from magnitude-squared parameters
+    let v = 0.5 * (1.0 + aa1.max(0.0).sqrt());
+    let w = 0.5 * (1.0 + bb1.max(0.0).sqrt());
+
+    let a0 = 0.5 * (v + (v * v + aa2).max(0.0).sqrt());
+    if a0.abs() < 1e-30 {
+        return PASSTHROUGH;
+    }
+    let inv_a0 = 1.0 / a0;
+    let a1 = (1.0 - v) * inv_a0;
+    let a2 = -0.25 * aa2 * inv_a0 * inv_a0;
+
+    let b0_raw = 0.5 * (w + (w * w + bb2).max(0.0).sqrt());
+    let b0 = b0_raw * inv_a0;
