+    let a_over_q_sq = a * f_ny_sq / (q * q);
+    let num_ny = (1.0 - a_f_ny_sq).powi(2) + a_over_q_sq;
+    let den_ny = (a - f_ny_sq).powi(2) + a_over_q_sq;
