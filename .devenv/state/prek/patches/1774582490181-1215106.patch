+        // Gain distribution between 1st-order and biquad sections.
+        // For odd orders, minimize gain in the 1st-order section to reduce
+        // its Nyquist cramping error. The biquad's matched design handles
+        // high frequencies much better than the 1st-order shelf.
+        let (gain_1st, gain_2nd) = if has_first_order {
+            let frac_1st = 0.20 / order as f64; // small fraction for 1st-order
+            let frac_2nd = (1.0 - frac_1st) / num_2nd as f64;
+            (effective_gain_db * frac_1st, effective_gain_db * frac_2nd)
+        } else {
+            let gain_per_pole = effective_gain_db / order as f64;
+            (gain_per_pole, gain_per_pole * 2.0)
