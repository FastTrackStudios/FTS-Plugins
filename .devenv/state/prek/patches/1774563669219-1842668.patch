+        // We measure the average absolute difference from input as a proxy
+        // for the amount of pitch shift applied.
+        let mut deviations = Vec::new();
+        for rate in &[0.5, 1.0, 2.0, 5.0] {
+            let mut voice = DetuneVoice::new(0.0);
+            voice.update(SR);
+            let mut diff_sum: f64 = 0.0;
+            let mut count = 0;
+            for i in 0..48000 {
+                let s = (2.0 * PI * 440.0 * i as f64 / SR).sin() * 0.5;
+                let out = voice.tick(s, *rate, 1.0, 0.0, 0.5, EffectType::Chorus);
+                if i > 4800 {
+                    // skip transient
+                    diff_sum += (out - s).abs();
+                    count += 1;
+                }
+            }
+            deviations.push(diff_sum / count as f64);
+        }
+        // All rates should produce similar deviation (within 3x of each other)
+        let min = deviations.iter().cloned().fold(f64::INFINITY, f64::min);
+        let max = deviations.iter().cloned().fold(0.0, f64::max);
+        assert!(
+            max < min * 3.0,
+            "Detune deviation should be roughly constant across rates: {:?}",
+            deviations
+        );
+    }
+
+    #[test]
+    fn diffuse_produces_output() {
+        test_engine_produces_output(Box::new(DiffuseVoice::new(0.0)));
+    }
+    #[test]
+    fn diffuse_no_nan() {
+        test_engine_no_nan(Box::new(DiffuseVoice::new(0.0)));
+    }
+
+    #[test]
+    fn drift_produces_output() {
+        test_engine_produces_output(Box::new(DriftVoice::new(0.0)));
+    }
+    #[test]
+    fn drift_no_nan() {
+        test_engine_no_nan(Box::new(DriftVoice::new(0.0)));
+    }
+
+    #[test]
+    fn drift_voices_differ() {
+        // Different phase offsets should produce different random sequences
+        let mut v1 = DriftVoice::new(0.0);
+        let mut v2 = DriftVoice::new(0.5);
+        v1.update(SR);
+        v2.update(SR);
+        let mut diff_sum: f64 = 0.0;
+        for i in 0..4800 {
+            let s = (2.0 * PI * 440.0 * i as f64 / SR).sin() * 0.5;
+            let o1 = v1.tick(s, 1.0, 0.5, 0.0, 0.5, EffectType::Chorus);
+            let o2 = v2.tick(s, 1.0, 0.5, 0.0, 0.5, EffectType::Chorus);
+            diff_sum += (o1 - o2).abs();
+        }
+        assert!(
+            diff_sum / 4800.0 > 0.001,
+            "Drift voices with different seeds should differ"
+        );
+    }
 }
